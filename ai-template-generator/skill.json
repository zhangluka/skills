{
  "name": "AI-Driven Template Generation System",
  "version": "1.0.0",
  "description": "A comprehensive skill for generating project templates using AI and structured documentation",
  "type": "template-generation",
  "category": "development-tools",
  "author": {
    "name": "AI Template Generator",
    "email": "support@ai-template-generator.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-template-generator/skill"
  },
  "keywords": [
    "ai",
    "template",
    "generator",
    "react",
    "vue",
    "nodejs",
    "project-initialization",
    "development-tools",
    "automation"
  ],
  "supported_models": [
    "deepseek-v3",
    "gpt-4",
    "claude-3-opus",
    "claude-3-sonnet"
  ],
  "supported_frameworks": [
    "react",
    "vue3",
    "nodejs-express",
    "nextjs",
    "nuxtjs"
  ],
  "prerequisites": {
    "node_version": ">=16.0.0",
    "ai_access": "Valid AI model API access",
    "documentation_skills": "Basic markdown writing skills"
  },
  "features": [
    {
      "name": "Structured Documentation",
      "description": "Modular markdown-based template definitions"
    },
    {
      "name": "AI Model Adaptation",
      "description": "Optimized prompts for different AI models"
    },
    {
      "name": "Code Templates",
      "description": "Reusable code snippets with copy-paste templates"
    },
    {
      "name": "Quality Assurance",
      "description": "Automated validation and verification tools"
    },
    {
      "name": "Extensibility",
      "description": "Easy to add new frameworks and templates"
    }
  ],
  "workflow": {
    "stages": [
      {
        "name": "Requirement Analysis",
        "description": "Define project requirements and constraints"
      },
      {
        "name": "Template Selection",
        "description": "Choose appropriate framework and template"
      },
      {
        "name": "Customization",
        "description": "Configure variables and specific requirements"
      },
      {
        "name": "AI Generation",
        "description": "Send structured prompt to AI for template generation"
      },
      {
        "name": "Validation",
        "description": "Verify generated project meets requirements"
      }
    ]
  },
  "configuration": {
    "default_ai_model": "deepseek-v3",
    "output_format": "markdown",
    "code_template_marker": "[CODE_TEMPLATE]",
    "variable_pattern": "${VARIABLE_NAME}",
    "validation_level": "strict"
  },
  "dependencies": {
    "external_tools": [],
    "internal_modules": [
      "template-validator",
      "prompt-optimizer"
    ]
  },
  "usage": {
    "cli_command": "skill-ai-template generate --template <template_name>",
    "direct_ai": "Copy main prompt to AI chat",
    "programmatic": "import { generateTemplate } from 'skill-ai-template'"
  },
  "quality_metrics": {
    "generation_time": "< 2 minutes",
    "success_rate": "> 95%",
    "completeness": "> 98%",
    "error_reduction": "> 80%"
  },
  "license": "MIT",
  "created": "2026-01-22",
  "updated": "2026-01-22",
  "contributors": [
    "AI Template Generator Team"
  ]
}